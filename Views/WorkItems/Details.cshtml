@model WorkLogPro.Models.WorkItem

@{
    ViewData["Title"] = "Work Item Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.Title</h1>
        <p class="text-muted mb-0">Work Item Details</p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        Back
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">

        <div class="row mb-4">
            <div class="col-md-6">
                <h6 class="text-muted">Priority</h6>
                <span class="badge @(Model.Priority == WorkLogPro.Models.Priority.Urgent ? "text-bg-danger" :
                                     Model.Priority == WorkLogPro.Models.Priority.High ? "text-bg-warning" :
                                     Model.Priority == WorkLogPro.Models.Priority.Medium ? "text-bg-primary" :
                                     "text-bg-secondary")">
                    @Model.Priority
                </span>
            </div>

            <div class="col-md-6">
                <h6 class="text-muted">Status</h6>
                <span class="badge @(Model.Status == WorkLogPro.Models.WorkStatus.Completed ? "text-bg-success" :
                                     Model.Status == WorkLogPro.Models.WorkStatus.InProgress ? "text-bg-primary" :
                                     Model.Status == WorkLogPro.Models.WorkStatus.Waiting ? "text-bg-warning" :
                                     "text-bg-secondary")">
                    @Model.Status
                </span>
            </div>
        </div>

        <div class="mb-4">
            <h6 class="text-muted">Description</h6>
            <p class="mb-0">@Model.Description</p>
        </div>

        <div class="row mb-4">
            <div class="col-md-4">
                <h6 class="text-muted">Category</h6>
                <p>@Model.Category?.Name</p>
            </div>

            <div class="col-md-4">
                <h6 class="text-muted">Due Date</h6>
                <p>@Model.DueDate.ToString("MMM dd, yyyy")</p>
            </div>

            <div class="col-md-4">
                <h6 class="text-muted">Created Date</h6>
                <p>@Model.CreatedDate.ToString("MMM dd, yyyy")</p>
            </div>
        </div>

        <div class="mb-4">
            <h6 class="text-muted">Follow Up Required</h6>
            <span class="badge @(Model.NeedsFollowUp ? "text-bg-danger" : "text-bg-secondary")">
                @(Model.NeedsFollowUp ? "Yes" : "No")
            </span>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-primary">
                Edit
            </a>

            <form asp-action="MarkCompleted" method="post">
                <input type="hidden" name="id" value="@Model.Id" />

                <button type="submit" class="btn btn-success">
                    Mark Completed
                </button>
            </form>

            <form asp-action="ToggleFollowUp" method="post">
                <input type="hidden" name="id" value="@Model.Id" />

                <button type="submit" class="btn btn-warning">
                    Toggle Follow Up
                </button>
            </form>

            <a asp-action="Delete"
               asp-route-id="@Model.Id"
               class="btn btn-danger">
                Delete
            </a>
        </div>

    </div>
</div>