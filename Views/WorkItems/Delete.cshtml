@model WorkLogPro.Models.WorkItem

@{
    ViewData["Title"] = "Delete Work Item";
}

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card border-danger shadow-sm">
            <div class="card-body">

                <h2 class="text-danger mb-3">
                    Delete Work Item
                </h2>

                <p>
                    Are you sure you want to delete this work item?
                </p>

                <hr />

                <h5>@Model.Title</h5>

                <p>
                    @Model.Description
                </p>

                <div class="mt-4 d-flex gap-2">

                    <a asp-action="Index"
                       class="btn btn-secondary">
                        Cancel
                    </a>

                    <form asp-action="DeleteConfirmed"
                          method="post">

                        <input type="hidden"
                               name="id"
                               value="@Model.Id" />

                        <button type="submit"
                                class="btn btn-danger">
                            Delete
                        </button>

                    </form>

                </div>

            </div>
        </div>

    </div>
</div>