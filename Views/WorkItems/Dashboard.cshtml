@model WorkLogPro.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-4">
            Dashboard
        </h1>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        New Work Item
    </a>
</div>

<div class="row g-3 mb-4">

    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Total</div>
                <div class="fs-3 fw-bold">
                    @Model.TotalItems
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Completed</div>
                <div class="fs-3 fw-bold">
                    @Model.CompletedItems
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">In Progress</div>
                <div class="fs-3 fw-bold">
                    @Model.InProgressItems
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Waiting</div>
                <div class="fs-3 fw-bold">
                    @Model.WaitingItems
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Overdue</div>
                <div class="fs-3 fw-bold">
                    @Model.OverdueItems
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-lg-2">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Follow Up</div>
                <div class="fs-3 fw-bold">
                    @Model.FollowUpItems
                </div>
            </div>
        </div>
    </div>

</div>

<div class="card shadow-sm">
    <div class="card-header">
        Recent Work Items
    </div>

    <div class="card-body">

        <table class="table table-hover">

            <thead>
                <tr>
                    <th>Title</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>Due Date</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model.RecentItems)
                {
                    <tr>
                        <td>@item.Title</td>
                        @* <td>@item.Status</td> *@
                        <td>
                            @(item.Status switch
                            {
                                WorkStatus.NotStarted => "Not Started",
                                WorkStatus.InProgress => "In Progress",
                                _ => item.Status.ToString()
                            })
                        </td>
                        <td>@item.Priority</td>
                        <td>@item.DueDate.ToString("MMM dd, yyyy")</td>
                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>