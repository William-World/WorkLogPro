@model WorkLogPro.ViewModels.WorkItemListViewModel

@{
    ViewData["Title"] = "Work Items";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Work Items</h1>
        <p class="text-muted mb-0">Track workplace tasks, issues, and follow-ups.</p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        New Work Item
    </a>
</div>

@* Summary Cards *@

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Total</div>
                <div class="fs-4 fw-bold">@Model.TotalItems</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Completed</div>
                <div class="fs-4 fw-bold">@Model.CompletedItems</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Pending</div>
                <div class="fs-4 fw-bold">@Model.PendingItems</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Urgent</div>
                <div class="fs-4 fw-bold">@Model.UrgentItems</div>
            </div>
        </div>
    </div>
</div>

@* Filters *@

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">

            <div class="col-md-3">
                <label asp-for="SearchTerm" class="form-label">Search</label>
                <input asp-for="SearchTerm"
                       name="searchTerm"
                       class="form-control"
                       placeholder="Search by title" />
            </div>

            <div class="col-md-3">
                <label asp-for="SelectedStatus" class="form-label">Status</label>
                <select asp-for="SelectedStatus"
                        name="selectedStatus"
                        class="form-select"
                        asp-items="Html.GetEnumSelectList<WorkLogPro.Models.WorkStatus>()">
                    <option value="">All Statuses</option>
                </select>
            </div>

            <div class="col-md-3">
                <label asp-for="SelectedCategoryId" class="form-label">Category</label>
                <select asp-for="SelectedCategoryId"
                        name="selectedCategoryId"
                        class="form-select"
                        asp-items="Model.Categories">
                    <option value="">All Categories</option>
                </select>
            </div>

            <div class="col-md-2">
                <div class="form-check">
                    <input asp-for="FollowUpOnly"
                           name="followUpOnly"
                           class="form-check-input" />
                    <label asp-for="FollowUpOnly" class="form-check-label">
                        Follow-up only
                    </label>
                </div>
            </div>

            <div class="col-md-1 d-grid">
                <button type="submit" class="btn btn-primary">
                    Filter
                </button>
            </div>

            <div class="col-12">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    Clear Filters
                </a>
            </div>

        </form>
    </div>
</div>

@* Table Shell *@

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Due Date</th>
                    <th>Follow Up</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.WorkItems.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No work items found.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.WorkItems)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.Priority</td>
                            @* <td>@item.Status</td> *@
                            <td>
                                @(item.Status switch
                                {
                                    WorkStatus.NotStarted => "Not Started",
                                    WorkStatus.InProgress => "In Progress",
                                    _ => item.Status.ToString()
                                })
                            </td>
                            <td>@item.DueDate.ToString("MMM dd, yyyy")</td>
                            <td>@(item.NeedsFollowUp ? "Yes" : "No")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>